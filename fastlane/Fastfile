default_platform(:ios)

platform :ios do
  desc "Upload App Store metadata and screenshots for StormClaim AI"
  lane :upload_assets do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64"),
      is_key_content_base64: true
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.stormclaim.ai",
      app_version: "1.0",
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      skip_app_version_update: true,
      submit_for_review: false,
      automatic_release: false,
      force: true
    )
  end
end
